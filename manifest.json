{
  "manifest_version": 3,
  "name": "GeminiText",
  "version": "1.0.0",
  "description": "Add AI-powered text commands to any webpage input field. Use ?m, ?r, ?f, ?c, ?s, ?l, ?t, ?e for instant text transformations.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GeminiText - AI Text Commands"
  }
}
